{
  "name": "@haus/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:smoke": "playwright test --project=setup --project=public --project=smoke --project=landing",
    "e2e:stack:up": "node scripts/e2e-stack.mjs up",
    "e2e:stack:up:build": "node scripts/e2e-stack.mjs up --build",
    "e2e:stack:down": "node scripts/e2e-stack.mjs down",
    "test:e2e:prod": "node scripts/e2e-stack.mjs up && playwright test",
    "test:e2e:prod:build": "node scripts/e2e-stack.mjs up --build && playwright test",
    "generate:e2e-routes": "node scripts/generate-e2e-routes.mjs",
    "prebuild": "npm run build --prefix ../../packages/contracts"
  },
  "dependencies": {
    "@haus/contracts": "file:../../packages/contracts",
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slot": "^1.2.3",
    "@tanstack/react-query": "^5.81.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.41.0",
    "lucide-react": "^0.525.0",
    "next": "^14.2.30",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.9.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2",
    "@types/node": "^22.15.32",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.30",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
