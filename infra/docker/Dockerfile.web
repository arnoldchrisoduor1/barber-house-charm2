FROM node:22-alpine AS builder
WORKDIR /app

RUN corepack enable pnpm

COPY package.json pnpm-workspace.yaml turbo.json ./
COPY packages/contracts ./packages/contracts
COPY apps/web ./apps/web

RUN pnpm install --filter @haus/web... --filter @haus/contracts...
RUN pnpm --filter @haus/contracts build

WORKDIR /app/apps/web
ENV NEXT_TELEMETRY_DISABLED=1
ENV API_URL=http://api:8080
ARG NEXT_PUBLIC_API_URL=http://localhost:18432
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
RUN pnpm run build

FROM node:22-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# Standalone output places server.js at the tracing root (/app), not apps/web/
COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /app/apps/web/public ./apps/web/public
COPY infra/docker/docker-entrypoint-web.sh /docker-entrypoint.sh
RUN sed -i 's/\r$//' /docker-entrypoint.sh && chmod +x /docker-entrypoint.sh

EXPOSE 3000
ENTRYPOINT ["sh", "/docker-entrypoint.sh"]
